# Copy file ini menjadi .env lalu isi nilainya.
# Jangan commit file .env ke version control!

# ── Firebase (Auth + Firestore) ──────────────────────────────────────────────
VITE_FIREBASE_API_KEY=What-You-Have
VITE_FIREBASE_AUTH_DOMAIN=What-You-Have
VITE_FIREBASE_PROJECT_ID=What-You-Have
VITE_FIREBASE_MESSAGING_SENDER_ID=What-You-Have
VITE_FIREBASE_APP_ID=What-You-Have

# ── Cloudinary (Image Upload) ────────────────────────────────────────────────
# Buka: https://cloudinary.com → Settings → Upload → Upload Presets
# Buat preset baru dengan Signing Mode = "Unsigned"
VITE_CLOUDINARY_CLOUD_NAME=What-You-Have
VITE_CLOUDINARY_UPLOAD_PRESET=What-You-Have
